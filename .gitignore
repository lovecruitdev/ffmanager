# ──────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.pytest_cache/

# ──────────────────────────────────────────────────────────────
# Virtual environments
# ──────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ──────────────────────────────────────────────────────────────
# IDE / Editor / Tooling
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
.qodo/
.claude/
*.swp
*.swo

# ──────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────
# PyInstaller / build outputs
# ──────────────────────────────────────────────────────────────
build/
dist/
*.manifest

# ──────────────────────────────────────────────────────────────
# Inno Setup output
# (installer.iss is tracked; the compiled installer payload is
#  produced by CI and uploaded to GitHub Releases, not committed.)
# ──────────────────────────────────────────────────────────────
FFM_Installer.exe
Setup_*.exe
Output/
*.iss.bak
release_notes.txt

# ──────────────────────────────────────────────────────────────
# Runtime caches and generated data
# (Re-fetched/regenerated by the app on startup.)
# ──────────────────────────────────────────────────────────────
offsets_cache.json
FFlags.json
FFlags.h
FFlags.hpp
FFlags.txt
Offsets.h
*_fflags.json
*_offsets.json
recovered_offsets.json
static_recovered.json
working_offsets_*.json

# Intentionally-tracked baselines (override the FFlags.hpp ignore above)
!data/FFlags.hpp
!src/data/FFlags_baseline.hpp
final_resolved_offsets.json
discovered_offsets.txt
discovery_log.txt
memory_proximity.txt
targets.json
last_version.txt
*.log

# ──────────────────────────────────────────────────────────────
# User data (lives in %USERPROFILE%/.FFlagManager normally;
# ignore any local copies that leak into the repo.)
# ──────────────────────────────────────────────────────────────
settings.json
user_flags.json
presets.json
fflags_history.json
known_flags.json
error.log
startup_error.log
bootstrapper_error.log

# ──────────────────────────────────────────────────────────────
# Native build intermediates
# (The compiled RFM*.exe helpers in src/native/ ARE tracked because
#  the app loads them at runtime; only the build intermediates are noise.)
# ──────────────────────────────────────────────────────────────
src/native/*.obj
src/native/*.pdb
src/native/*.ilk
src/native/*.exp
src/native/*.lib
src/native/discovered_flags.json

# ──────────────────────────────────────────────────────────────
# Local test / dev / scratch files (not used by main.pyw)
# ──────────────────────────────────────────────────────────────
simulate_skips.py
test_skips.py
verify_*.py
test_discovery.py
check_*.py
reproduce_*.py
generate_icon.py
scratch/
unwanted/
dump/
plans/
scripts/*
!scripts/update_version.py
fflag_apply_testing/
fflag_offset_testing/
*.tmp
/tmp/

# ──────────────────────────────────────────────────────────────
# Unused brand assets
# (The app uses ffm_v3_logo.ico for the icon; Logo.png is not
#  referenced by main.pyw at runtime.)
# ──────────────────────────────────────────────────────────────
Logo.png
ffm_final_icon.ico
app_icon.ico
icon.ico
